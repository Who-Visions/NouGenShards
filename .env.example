# NouGenShards Environment Template
# Copy this to .env and fill in your keys.
# NEVER commit your .env file to source control.

# --- Who Visions Cloud (Pro) ---
# Your NGS Cloud Gateway URL (e.g., your HF Space URL)
NGS_CLOUD_URL=https://your-node.hf.space
# Your Who Visions Pro user token
NGS_CLOUD_TOKEN=your_pro_token_here

# --- BYOK (Bring Your Own Key) ---
# Optional: You can also set these via 'nougen auth set-key <provider> <key>'
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
HUGGINGFACE_API_KEY=hf_...
OPENROUTER_API_KEY=sk-or-...

# --- Node Configuration (Server-Side) ---
# If you are running your own node, set the required write-auth token here
NGS_NODE_TOKEN=your_private_node_token
