# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Databases
*.db
*.sqlite3

# Local configuration
mcp.config.json
.env
secrets/
.mcp-locks/

# Keymaker vault (DPAPI-encrypted, user-bound — never ship). Covers the CSV
# ledger and service_accounts/ JSON that *.db alone would miss.
.nougen_vault/
*_secrets.csv
*_secrets.db
service_accounts/

# Fleet test reports / ad-hoc audit output
tools/reports/
ts/audit_results.json

# Virtual environments & session logs
.venv/
venv/
transcript.log
.handoffs/
.vault/
pending_shards/

# Node dependencies
node_modules/
package-lock.json

# Development tools
.pytest_cache/
.benchmarks/
.agents/

# Build artifacts
dist/
build/
*.egg-info/

# Tauri / Rust
src-tauri/target/
src-tauri/gen/
src-tauri/bin/*.exe
src-tauri/bin/build/
src-tauri/bin/dist/
# Binary icon formats are regenerated locally via `tauri icon` (HF rejects them)
src-tauri/icons/*.ico
src-tauri/icons/*.icns
src-tauri/icons/android/
src-tauri/icons/ios/

# OS specific
Thumbs.db
.DS_Store
