# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Databases
*.db
*.sqlite3

# Local configuration
mcp.config.json
.env
secrets/
.mcp-locks/

# Virtual environments & session logs
.venv/
venv/
transcript.log
.handoffs/

# Node dependencies
node_modules/
package-lock.json

# Development tools
.pytest_cache/
.benchmarks/
.agents/

# Build artifacts
dist/
build/
*.egg-info/

# Tauri / Rust
src-tauri/target/
src-tauri/gen/
src-tauri/bin/*.exe
src-tauri/bin/build/
src-tauri/bin/dist/
# Binary icon formats are regenerated locally via `tauri icon` (HF rejects them)
src-tauri/icons/*.ico
src-tauri/icons/*.icns
src-tauri/icons/android/
src-tauri/icons/ios/

# OS specific
Thumbs.db
.DS_Store
