# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Databases
*.db
*.sqlite3

# Local configuration
mcp.config.json
.env
secrets/
.mcp-locks/

# Keymaker vault (DPAPI-encrypted, user-bound — never ship). Covers the CSV
# ledger and service_accounts/ JSON that *.db alone would miss.
.nougen_vault/
*_secrets.csv
*_secrets.db
service_accounts/

# Fleet test reports / ad-hoc audit output
tools/reports/
ts/audit_results.json

# Virtual environments & session logs
.venv/
venv/
transcript.log
.handoffs/
.nougen-hooks/
.vault/
pending_shards/

# Node dependencies
node_modules/
package-lock.json

# Development tools
.pytest_cache/
.benchmarks/
.agents/

# Build artifacts
dist/
build/
*.egg-info/

# Tauri / Rust
src-tauri/target/
src-tauri/gen/
src-tauri/bin/*.exe
src-tauri/bin/build/
src-tauri/bin/dist/
# Binary icon formats are regenerated locally via `tauri icon` (HF rejects them)
src-tauri/icons/*.ico
src-tauri/icons/*.icns
src-tauri/icons/android/
src-tauri/icons/ios/

# Vault introspection / dump utilities — local-only crowbars that sit next to
# the encrypted vault. Never ship in the public package.
dump_vault.py
dump_elevated.py
dump_memories_schema.py
get_memories_schema.py
list_tables.py
list_backup_tables.py
tmp_dump.py
tmp_dump_global.py
tools/read_vault_shards.py
load_secrets.py
count_shards.py
dream_all.py
fast_ingest.py

# One-time / version-numbered migration scripts — history belongs in git, not
# in filenames. Local-only.
migrate_vault.py
migrate_vault_v2.py
incremental_migration.py
incremental_migration_v2.py
migrate_memories.py
verify_swap.py
fix_types.py
check_unsharded.py
shard_vault_files.py

# Fleet / orchestration tooling — internal, not part of the public package
# (banned from the user-facing tree by the project constitution).
tools/fleet_test.py
tools/nougenai_fleet_registry_mcp.py

# OS specific
Thumbs.db
.DS_Store
*.nougen-bak
