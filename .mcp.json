{
  "mcpServers": {
    "nougen-shards": {
      "command": "python",
      "args": ["-m", "nougen_shards.mcp"],
      "env": {
        "PYTHONPATH": "src",
        "NOUGEN_VAULT_DIR": ".vault"
      }
    },
    "ollama": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "ollama-mcp"],
      "env": {
        "OLLAMA_HOST": "http://127.0.0.1:11434"
      }
    },
    "sequentialthinking": {
      "type": "http",
      "url": "https://remote.mcpservers.org/sequentialthinking/mcp"
    },
    "Ref": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "-e", "REF_API_KEY", "mcp/ref-tools-mcp"],
      "env": {
        "REF_API_KEY": "${REF_API_KEY}"
      }
    }
  }
}
